{
  "mcpServers": {
    "airbnb": {
      "command": "npx",
      "args": ["-y", "@openbnb/mcp-server-airbnb"]
    },
    "google-flights": {
      "command": "npx",
      "args": ["-y", "google-flights-mcp-server"]
    },
    "public-transport": {
      "command": "npx",
      "args": ["-y", "mcp-server-public-transport"]
    },
    "tfl": {
      "command": "npx",
      "args": ["-y", "@daanrongen/tfl-mcp"]
    },
    "ferryhopper": {
      "type": "remote",
      "url": "https://mcp.ferryhopper.com/mcp"
    },
    "gmail": {
      "type": "http",
      "url": "https://gmail.mcp.claude.com/mcp"
    },
    "google-calendar": {
      "type": "http",
      "url": "https://gcal.mcp.claude.com/mcp"
    }
  }
}

{
  "mcpServers": {
    "airbnb": {
      "command": "npx",
      "args": ["-y", "@openbnb/mcp-server-airbnb"]
    },
    "google-flights": {
      "command": "npx",
      "args": ["-y", "google-flights-mcp-server"]
    },
    "public-transport": {
      "command": "npx",
      "args": ["-y", "mcp-server-public-transport"]
    },
    "tfl": {
      "command": "npx",
      "args": ["-y", "@daanrongen/tfl-mcp"]
    },
    "ferryhopper": {
      "type": "remote",
      "url": "https://mcp.ferryhopper.com/mcp"
    },
    "gmail": {
      "type": "http",
      "url": "https://mcp.google.com/gmail",
      "description": "Read-only Gmail access for detecting booking confirmations (airline and hotel emails)"
    },
    "google-calendar": {
      "type": "http",
      "url": "https://mcp.google.com/calendar",
      "description": "Create trip events, flight reminders, and accommodation bookings in Google Calendar"
    }
  }
}
